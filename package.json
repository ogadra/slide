{
  "name": "slide",
  "type": "module",
  "version": "0.0.1",
  "description": "ogadra's slides website.",
  "author": "ogadra",
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "wrangler dev --ip 0.0.0.0 --env dev",
    "start": "wrangler dev --ip 0.0.0.0 --env dev",
    "deploy:prd": "wrangler deploy",
    "deploy:dev": "wrangler deploy --env dev"
  },
  "private": true,
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@slidev/cli": "^52.16.0",
    "@slidev/client": "^52.17.0",
    "playwright-chromium": "^1.59.1",
    "slidev-theme-purplin": "^1.2.0",
    "typescript": "^6.0.3",
    "unocss": "^66.7.3",
    "vite": "^8.1.4",
    "vue": "^3.5.33",
    "wrangler": "^4.103.0"
  },
  "dependencies": {
    "vue-i18n": "^11.4.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "playwright-chromium",
      "sharp",
      "vue-demi",
      "workerd"
    ],
    "patchedDependencies": {
      "@slidev/client@52.16.0": "patches/@slidev__client@52.16.0.patch"
    }
  }
