    "@hono/vite-dev-server": "^0.26.0",
    "bcrypt-ts": "^8.0.1",
    "hono": "^4.12.8",
    "nanoid": "^5.1.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@cloudflare/sandbox": "^0.10.3",
    "@cloudflare/workers-types": "^4.20260317.1",
    "typescript": "^6.0.3"
  }
}
