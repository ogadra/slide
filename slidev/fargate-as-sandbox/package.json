{
  "name": "fargate-as-sandbox",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "author": "ogadra",
  "scripts": {
    "build": "pnpm run build:slidev && pnpm run build:copy",
    "build:copy": "cp -r ./slides-export ../../dist/fargate-as-sandbox",
    "build:slidev": "slidev build --base /fargate-as-sandbox/ --out ../../dist/fargate-as-sandbox",
    "dev": "slidev --open",
    "export": "slidev export",
    "export:png": "slidev export --format png"
  }
}
